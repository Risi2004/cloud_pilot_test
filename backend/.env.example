# CloudPilot Backend Environment Variables

# Port to listen on (Render will automatically set PORT to 10000 by default)
PORT=5000

# MongoDB Connection String (e.g. MongoDB Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/cloudpilot?retryWrites=true&w=majority

# Ollama API Configuration (for local/remote LLM analysis)
OLLAMA_API_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b
